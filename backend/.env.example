# ---- Django ----
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origens permitidas para CORS/CSRF (frontend)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ---- Banco (PostgreSQL) ----
# Em dev sem docker, deixe vazio para cair no SQLite.
DATABASE_URL=postgres://convida:convida@db:5432/convida

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0

# ---- Google SSO ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- E-mail (SMTP) ----
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Convida <no-reply@convida.app>
