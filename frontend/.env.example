# URL base da API (inclua o prefixo /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# URL pública do site (usada em SEO: canonical, sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL=https://convida.app

# OAuth Google (client id público, usado no fluxo de login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
